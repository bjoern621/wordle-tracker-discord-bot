# Every variable below is required. A missing or malformed value stops the bot
# at startup with the exact list of problems; there are no defaults or fallbacks.

# Discord bot token from the Developer Portal (Bot tab -> Reset Token).
# Keep this secret. The real file is .env, which is gitignored.
DISCORD_TOKEN=

# The bot works in every server it is invited to. The channel it tracks is chosen
# per server at runtime with the /set-channel command (admin only) and stored in
# the database, so each server resumes tracking after a restart. Until a channel
# is set, the bot ignores that server.

# Group timezone (IANA name). The daily summary reports "yesterday", resolved in
# this zone, so it must match where the group plays. e.g. Europe/Berlin, UTC.
TIMEZONE=Europe/Berlin

# Manual name -> user-id overrides for summary entries shown as plain @text
# (a player whose nickname differs from their global name and is not a member
# the bot can resolve). Optional, comma separated, may be left empty. Example:
# PLAYER_ALIASES=Tim=792090533392678933,Björn=386925022285004800
PLAYER_ALIASES=

# Parse the per-game "X was playing" grid image for same-day results. true/false.
ENABLE_ACTIVITY_IMAGE=true

# --- Database (PostgreSQL) ---
# Password for the bundled Postgres container.
POSTGRES_PASSWORD=wordle
# Host port to expose Postgres on (container port stays 5432). For local DB tools.
POSTGRES_PORT=5432
# Connection string used by the bot (node-postgres) and local db tools.
# docker-compose overrides this to point at the db service; set it here for
# running the bot or db tools outside docker.
DATABASE_URL=postgresql://wordle:wordle@localhost:5432/wordle

# Logger only (task logger): download image attachments and embed images next to
# the JSON dump. Discord CDN URLs expire within ~24h, so this keeps a replayable
# corpus for testing and re-tuning the parsers. Images are sorted by message kind
# into data/images/<category>/ (summary, solo, multi, ...) and prefixed with the
# puzzle number, so a day-summary board is easy to find and turn into a test
# fixture. The puzzle number is resolved in TIMEZONE. true/false.
SAVE_IMAGES=false

# Scan channel history once on startup to import past results.
BACKFILL_ON_START=false

# How many past messages to scan for backfill (startup and /backfill default).
# The group's full history needs a large value (one summary per day).
BACKFILL_LIMIT=5000
