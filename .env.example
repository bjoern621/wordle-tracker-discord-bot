# Discord bot token from the Developer Portal (Bot tab -> Reset Token).
# Keep this secret. The real file is .env, which is gitignored.
DISCORD_TOKEN=

# Restrict the bot to a single server (guild). When set, the bot only registers
# commands, syncs members and ingests in this server, ignoring every other server
# it is in. Right-click the server icon -> Copy Server ID.
GUILD_ID=

# Channel the bot reads results from. Leave empty to read every channel it sees.
# Enable Developer Mode in Discord, then right-click the channel -> Copy Channel ID.
WORDLE_CHANNEL_ID=

# Group timezone (IANA name). The daily summary reports "yesterday", resolved in
# this zone, so it must match where the group plays. e.g. Europe/Berlin, UTC.
TIMEZONE=Europe/Berlin

# Manual name -> user-id overrides for summary entries shown as plain @text
# (a player whose nickname differs from their global name and is not a member
# the bot can resolve). Comma separated. Example:
# PLAYER_ALIASES=Tim=792090533392678933,Björn=386925022285004800
PLAYER_ALIASES=

# Parse the per-game "X was playing" grid image for same-day results. The daily
# summary covers everyone the next day, so this is optional. true/false.
ENABLE_ACTIVITY_IMAGE=true

# --- Database (PostgreSQL) ---
# Password for the bundled Postgres container.
POSTGRES_PASSWORD=wordle
# Host port to expose Postgres on (container port stays 5432). For local DB tools.
POSTGRES_PORT=5432
# Connection string used by the bot (node-postgres) and local db tools.
# docker-compose overrides this to point at the db service; set it here for
# running the bot or db tools outside docker.
DATABASE_URL=postgresql://wordle:wordle@localhost:5432/wordle

# Reaction added to a message once its result is captured. Empty to disable.
CONFIRM_REACTION=✅

# Reaction marking that a newer message corrected an earlier stored result.
OVERRIDE_REACTION=🔁

# Scan channel history once on startup to import past results.
BACKFILL_ON_START=false

# How many past messages to scan for backfill (startup and /backfill default).
# The group's full history needs a large value (one summary per day).
BACKFILL_LIMIT=5000
